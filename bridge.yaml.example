transport: telegram
runtime: cursor

telegram:
  token: ${TELEGRAM_BOT_TOKEN}
  allowed_chats:
    - "your-chat-id"

cursor:
  api_key: ${CURSOR_API_KEY}
  model: claude-opus-4-6

# Optional: local conversation logs
session:
  log_dir: ~/.thronglets/logs

  # Optional: sync conversations to a recall API
  # recall_api: https://your-api/api/sync/ingest
  # recall_key: ${YOUR_API_KEY}
