{
  "name": "agent-bridge",
  "version": "0.3.0",
  "description": "Bridge local workspace agent capabilities to messaging platforms — multi-agent support with Cursor, Claude Code, and Codex",
  "type": "module",
  "bin": {
    "agent-bridge": "./bin/agent-bridge.js"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.148",
    "@cursor/sdk": "^1.0.0",
    "@openai/codex-sdk": "^0.133.0",
    "node-telegram-bot-api": "^0.66.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
