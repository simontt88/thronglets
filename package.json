{
  "name": "thronglets",
  "version": "0.7.0",
  "description": "Thronglets — multi-agent fleet orchestrator for Telegram/Lark/Discord with Cursor, Claude Code, and Codex",
  "type": "module",
  "bin": {
    "thronglets": "./bin/kenyalang.js"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "publish:dashboard": "bash scripts/publish-dashboard.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.148",
    "@cursor/sdk": "^1.0.0",
    "@openai/codex-sdk": "^0.133.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.66.0",
    "ws": "^8.21.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
