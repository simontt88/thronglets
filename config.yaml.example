transport: telegram

telegram:
  token: ${TELEGRAM_BOT_TOKEN}
  allowed_chats:
    - "your-chat-id"    # Get via: send /start to @userinfobot on Telegram

agents:
  - name: default
    runtime: cursor
    api_key: ${CURSOR_API_KEY}  # Get from: https://cursor.com/settings
    model: claude-opus-4-6

# Dispatcher: AI-powered message router that manages the fleet
dispatcher:
  enabled: true
  # workspace: dispatch  # auto-created under ~/.thronglets/dispatch

# Fleet communication rules
fleet:
  # comms: who can talk to whom
  #   swarm — throngs can message any other throng freely
  #   hive  — throngs can only report to the dispatcher (default)
  #   leash — throngs cannot send messages, only reply to human
  comms: hive

  # timeouts: control agent lifecycle timing
  # timeouts:
  #   send_timeout_ms: 3600000        # 1 hour — max time waiting for agent response
  #   session_max_age_ms: 1800000     # 30 min — idle session auto-close
  #   stuck_working_grace_ms: 3660000 # 1h + 1min — grace before recovering stuck agents
  #   health_check_interval_ms: 30000 # 30 sec — health check frequency

  # visibility: what you see in Telegram
  visibility:
    # inter_agent: inter-agent message notifications
    #   full    — show full message content
    #   summary — one-line "Orix → Zuri" notification (default)
    #   off     — no notifications
    inter_agent: summary
    # tool_calls: show fleet tool execution logs
    tool_calls: true

# Optional: local conversation logs
session:
  log_dir: ~/.thronglets/logs
